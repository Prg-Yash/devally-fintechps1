// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  isBanned      Boolean   @default(false)
  bannedAt      DateTime?
  banExpiresAt  DateTime?
  image         String?
  phoneNumber   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions         Session[]
  accounts         Account[]
  twoFactorEnabled Boolean?    @default(false)
  twofactors       TwoFactor[]
  purchases        Purchase[]
  passkeys         Passkey[]

  createdAgreements  Agreement[] @relation("Creator")
  receivedAgreements Agreement[] @relation("Receiver")
  agreementChangeRequests AgreementChangeRequest[]
  raisedTickets      Ticket[]    @relation("RaisedTickets")
  ticketsAgainstMe   Ticket[]    @relation("TicketsAgainstUser")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?
  aaguid       String?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model Purchase {
  id                String   @id @default(cuid())
  userId            String
  amount            Float
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchase")
}

model Agreement {
  id          String   @id @default(cuid())
  title       String
  description String?
  amount      Float
  status      String   @default("DRAFT")
  currency    String   @default("USDC")
  dueDate     DateTime?
  fundingError String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Protocol Sync Fields
  projectId       Int?    @unique // On-chain project index
  receiverAddress String? // Target wallet address
  transactionHash String? // On-chain creation proof 
  clientRefId     String? // Deterministic off-chain to on-chain ref

  creatorId String
  creator   User   @relation("Creator", fields: [creatorId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  milestones Milestone[]
  changeRequests AgreementChangeRequest[]
  tickets    Ticket[]

  @@index([creatorId])
  @@index([receiverId])
  @@index([projectId])
  @@map("agreement")
}

model AgreementChangeRequest {
  id          String    @id @default(cuid())
  note        String
  createdAt   DateTime  @default(now())

  agreementId String
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User     @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@index([requestedById])
  @@map("agreement_change_request")
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String
  reason      String
  status      String         @default("OPEN")
  severity    TicketSeverity @default(LOW)
  evidenceUrl String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  raisedById String
  raisedBy   User   @relation("RaisedTickets", fields: [raisedById], references: [id], onDelete: Cascade)

  againstUserId String
  againstUser   User   @relation("TicketsAgainstUser", fields: [againstUserId], references: [id], onDelete: Cascade)

  agreementId String?
  agreement   Agreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  @@index([raisedById])
  @@index([againstUserId])
  @@index([agreementId])
  @@index([status])
  @@index([severity])
  @@map("ticket")
}

enum TicketSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  amount      Float
  status      String    @default("PENDING")
  paidAt      DateTime?
  payoutTxHash String?
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agreementId String
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@map("milestone")
}