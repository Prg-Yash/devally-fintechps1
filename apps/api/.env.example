# Razorpay Secret Keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Razorpay Webhook Secret (Set this in the Razorpay Dashboard to authenticate webhooks securely)
RAZORPAY_WEBHOOK_SECRET=your_custom_webhook_secret_here

# Database URL used by Prisma to track the stablecoin Purchases
DATABASE_URL=""
PORT=5000

# INR to PCC conversion rate (default: 1 INR = 1 PCC)
INR_TO_PCC_RATE=1

# PCC on-chain distribution config
PCC_CONTRACT_ADDRESS=0xYourPayCrowCoinContractAddress
PCC_DISTRIBUTOR_PRIVATE_KEY=0xYourOwnerPrivateKey
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-project-id

# Escrow admin release config
ESCROW_CONTRACT_ADDRESS=0xYourPayCrowEscrowContractAddress
ESCROW_ADMIN_PRIVATE_KEY=0xYourEscrowAdminPrivateKey

# Email notification config (Gmail App Password)
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-google-app-password
NOTIFICATION_EMAIL_FROM=your-email@gmail.com

# Next.js notification API proxy target (where notifications are managed)
NOTIFICATION_API_BASE_URL=http://localhost:3000/api/notifications
# Shared secret expected by Next.js notification routes for write operations
NOTIFICATION_API_SECRET=your-shared-notification-secret
